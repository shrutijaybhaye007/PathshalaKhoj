{
  "name": "pathshalakhoj-backend",
  "version": "2.0.0",
  "description": "Backend API for PathshalaKhoj — India College Finder",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "npm run refine && node server.js",
    "dev": "nodemon server.js",
    "seed": "node db/seed.js",
    "seed:admin": "node db/seed-admin.js",
    "seed:aishe": "node db/seed_aishe.js",
    "seed:nirf": "node db/seed_nirf.js",
    "seed:nirf-check": "node db/spot_check_nirf.js",
    "seed:courses": "node db/seed_courses.js",
    "db:sanitize": "node db/sanitize_db.js",
