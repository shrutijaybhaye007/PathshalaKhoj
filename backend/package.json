    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "indian-colleges": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "rss-parser": "^3.13.0",
    "xlsx": "^0.18.5"
