# ─── PathshalaKhoj Backend Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git (it is already in .gitignore).

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (default: 4000)
PORT=4000

# Origin that the CORS policy allows. In production, set this to your
# actual domain, e.g. https://pathshalakhoj.com
ALLOWED_ORIGIN=http://localhost:4000

# ─── Authentication ───────────────────────────────────────────────────────────
# REQUIRED: A long, random secret for signing JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server will refuse to start if this is not set.
JWT_SECRET=replace_me_with_a_long_random_secret

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# To enable Google Sign-In, set your Google OAuth 2.0 Client ID here.
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Leave blank to disable Google Sign-In (email/password login still works).
GOOGLE_CLIENT_ID=

# ─── Admin Account ────────────────────────────────────────────────────────────
# Run `npm run seed:admin` after first boot to create the admin account.
ADMIN_EMAIL=admin@pathshalakhoj.com
ADMIN_PASSWORD=replace_me_with_a_strong_password
ADMIN_NAME=System Admin

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL Connection String (Neon / Supabase / Render Postgres / Local)
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Email (Password Reset) ────────────────────────────────────────────────────
# Required to send real password reset emails to users.
#
# Gmail App Password setup:
#   1. Enable 2-Factor Authentication on your Google Account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail"
#   4. Paste the 16-character code (without spaces) as SMTP_PASS below
#
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# The public URL of your site (no trailing slash).
# Used for the reset link in emails.
SITE_URL=https://pathshalakhoj.onrender.com

